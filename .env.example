# ── Gmail API ────────────────────────────────────────────────
# Download from Google Cloud Console → APIs & Services → Credentials
GMAIL_CREDENTIALS_PATH=credentials/credentials.json
GMAIL_TOKEN_PATH=credentials/token.json

# ── Email Filters ─────────────────────────────────────────────
# Comma-separated Gmail labels to include (e.g. "INBOX,newsletters")
GMAIL_LABELS=INBOX
# Comma-separated sender domains or addresses to include (leave blank = all)
# Example: "substack.com,newsletter@example.com,medium.com"
GMAIL_SENDER_FILTER=

# ── OpenRouter AI ─────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
# Any model slug from openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ── SMTP Delivery ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=you@gmail.com
# Comma-separated list of newsletter recipients
SMTP_TO=you@gmail.com

# ── Newsletter Settings ───────────────────────────────────────
NEWSLETTER_SUBJECT=Your Email Digest
# Days of week to send: 0=Mon,1=Tue,2=Wed,3=Thu,4=Fri,5=Sat,6=Sun
SCHEDULE_DAYS=0,3
# Time to send (24h, your local timezone)
SCHEDULE_TIME=08:00
